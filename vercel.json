{
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "edge"
    },
    "api/diagnostics.js": {
      "memory": 1024
    },
    "api/diagnostics-edge.js": {
      "runtime": "edge"
    }
  },
  "routes": [
    { "src": "/diagnostics-edge", "dest": "/api/diagnostics-edge.js" },
    { "src": "/diagnostics", "dest": "/api/diagnostics.js" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
